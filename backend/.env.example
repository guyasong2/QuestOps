SECRET_KEY=django-insecure-placeholder-key-replace-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,questops.yourdomain.com

# --- AI Mode: 'online' (DeepSeek cloud) or 'offline' (Ollama local) ---
AI_MODE=offline

# Offline backend — Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Online backend — DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_BASE_URL=https://api.deepseek.com

# --- AWS S3 Configuration (Optional, for media storage) ---
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_STORAGE_BUCKET_NAME=your_s3_bucket_name
AWS_S3_REGION_NAME=us-east-1

# Production Security (set to True when using HTTPS)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
