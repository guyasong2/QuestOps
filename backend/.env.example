SECRET_KEY=django-insecure-placeholder-key-replace-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-ec2-hostname.compute-1.amazonaws.com

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://your-ec2-hostname.compute-1.amazonaws.com

# Database — set this to use Postgres, leave empty to use SQLite
DATABASE_URL=postgres://user:password@db:5432/questops

# --- AI Mode: 'online' (DeepSeek cloud) or 'offline' (Ollama local) ---
AI_MODE=offline

# Offline backend — Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Online backend — DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_BASE_URL=https://api.deepseek.com

# --- AWS S3 Configuration (required for avatar uploads) ---
# On EC2: leave the key/secret BLANK and attach an IAM role to the instance instead.
# For local dev without a role, fill in the key and secret.
# AWS_ACCESS_KEY_ID=your_aws_access_key_id      # optional if using IAM role
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key      # optional if using IAM role
AWS_STORAGE_BUCKET_NAME=questops-565898898566-us-east-1-an
AWS_S3_REGION_NAME=us-east-1
AWS_LOCATION=avatars

# Production Security (set to True when using HTTPS)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
